# OpenSpace - Variables d'environnement

# App
APP_PORT=8000
APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=openspace
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=your-access-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15
JWT_REFRESH_EXPIRY=168

# Payment - CinetPay
CINETPAY_API_KEY=your-cinetpay-api-key
CINETPAY_SITE_ID=your-cinetpay-site-id
CINETPAY_SECRET_KEY=your-cinetpay-secret-key
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com

# Payment - NotchPay
NOTCHPAY_PUBLIC_KEY=your-notchpay-public-key
NOTCHPAY_SECRET_KEY=your-notchpay-secret-key
NOTCHPAY_BASE_URL=https://api.notchpay.co

# Webhooks
WEBHOOK_BASE_URL=http://localhost:8080

# Domain - OpenProvider
OPENPROVIDER_USERNAME=your-openprovider-username
OPENPROVIDER_PASSWORD=your-openprovider-password
OPENPROVIDER_API_URL=https://api.openprovider.eu/v1beta
OPENPROVIDER_NAMESERVERS=ns1.openspace.cm,ns2.openspace.cm
